    {
      "parameters": {
        "jsCode": "const fullText = $json.text || \"\";\nconst rawSubject = $json.subject || \"\";\n\nlet cleanSubject = rawSubject\n  .replace(/^(re:\\s*)+/i, \"Re: \")\n  .replace(/^(fw:\\s*)+/i, \"\")\n  .trim();\n\nif (!/^Re:/i.test(cleanSubject) && /^Re:/i.test(rawSubject)) {\n  cleanSubject = rawSubject;\n}\n\nconst lines = fullText.split(\"\\n\");\n\nlet feedbackLines = [];\nlet draftLines = [];\nlet inQuote = false;\n\nfor (const line of lines) {\n  if (line.trim().startsWith(\">\")) {\n    inQuote = true;\n    draftLines.push(line.replace(/^> ?/, \"\"));\n  } else if (!inQuote) {\n    feedbackLines.push(line);\n  }\n}\n\nlet feedback = feedbackLines.join(\" \").trim();\nfeedback = feedback.replace(/На .*нап.*:/gi, \"\").trim();\n\nlet originalDraft = draftLines.join(\"\\n\");\n\noriginalDraft = originalDraft\n  .replace(/Hello,/gi, \"\")\n  .replace(/Here is your LinkedIn post draft:/gi, \"\")\n  .replace(/📝 LINKEDIN POST DRAFT/gi, \"\")\n  .replace(/━━━━━━━━━━━━━━━━━━━━━━/g, \"\")\n  .replace(/Please reply to this email[\\s\\S]*/i, \"\")\n  .trim();\n\nconst imageKeywords = [\n  \"image\",\n  \"images\",\n  \"picture\",\n  \"photo\",\n  \"visual\",\n  \"background\",\n  \"color\",\n  \"car\",\n  \"logo\",\n  \"design\"\n];\n\nlet textFeedbackParts = [];\nlet imageFeedbackParts = [];\n\nconst sentences = feedback.split(/(?<=\\.)\\s+/);\n\nfor (const sentence of sentences) {\n  const lower = sentence.toLowerCase();\n\n  if (imageKeywords.some(keyword => lower.includes(keyword))) {\n    imageFeedbackParts.push(sentence.trim());\n  } else if (sentence.trim() !== \"\") {\n    textFeedbackParts.push(sentence.trim());\n  }\n}\n\nconst textFeedback = textFeedbackParts.join(\" \").trim();\nconst imageFeedback = imageFeedbackParts.join(\" \").trim();\n\nreturn [\n  {\n    json: {\n      feedback,\n      textFeedback,\n      imageFeedback,\n      originalDraft,\n      cleanSubject,\n      threadId: $json.threadId,\n      messageId: $json.id\n    }\n  }\n];"
      },
